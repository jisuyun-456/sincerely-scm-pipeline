  "trigger_automation": {
    "description": "AS-IS에서 수동이었던 프로세스 → TO-BE에서 DB 트리거로 자동화",
    "automations": [
      {
        "name": "재고 자동갱신",
        "trigger_on": "mm.stock_movements INSERT (status=completed)",
        "action": "wms.quants.system_qty 자동 증감",
        "as_is": "WMS > material에 수동 갱신",
        "movement_types": ["101(입하)", "122(반품출고)", "161(반품입고)", "201(출고)", "261(임가공투입)", "262(임가공완성)", "301(이동)", "551(폐기)", "601(배송출고)", "701(실사과잉)", "702(실사부족)"]
      },
      {
        "name": "예약 재고 갱신",
        "trigger_on": "mm.reservations INSERT/UPDATE/DELETE",
        "action": "wms.quants.reserved_qty 자동 증감",
        "as_is": "없음 (예약 개념 없음)"
      },
      {
        "name": "입하 전표",
        "trigger_on": "mm.goods_receipts INSERT",
        "action": "finance.accounting_entries 자동생성 (DR 원재료/CR 매입채무)",
        "as_is": "더존 수동 입력"
      },
      {
        "name": "임가공 전표",
        "trigger_on": "mm.stock_movements INSERT (type=261/262)",
        "action": "finance.accounting_entries 자동생성 (DR 재공품/CR 원재료, DR 제품/CR 재공품)",
        "as_is": "더존 수동 입력"
      },
      {
        "name": "출고 전표",
        "trigger_on": "mm.stock_movements INSERT (type=601)",
        "action": "finance.accounting_entries 자동생성 (DR 매출원가/CR 제품)",
        "as_is": "더존 수동 입력"
      },
      {
        "name": "운임 전표",
        "trigger_on": "tms.freight_orders UPDATE (billing_status=billed)",
        "action": "finance.accounting_entries 자동생성 (DR 운반비/CR 미지급금)",
        "as_is": "더존 수동 입력"
      },
      {
        "name": "실사 조정 전표",
        "trigger_on": "wms.inventory_count_items UPDATE (adjustment_approved=TRUE)",
