# Virtual SAP Simulation — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git

# Supabase (new dedicated project: virtual-sap-sim)
VSAP_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VSAP_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Simulation settings
VSAP_MODE=manual           # manual | daily | backfill
VSAP_DRY_RUN=false         # set to true for local testing without DB writes
VSAP_ORDERS_PER_TICK=2     # orders to generate per tick (keep low for free tier)

# Slack notifications (optional — reuse from settlement)
SLACK_BOT_TOKEN=xoxb-...
SLACK_DM_USER_ID=U...
