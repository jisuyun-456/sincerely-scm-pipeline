PAGE_SIZE = 100  # Airtable API 페이지 크기
RATE_LIMIT_DELAY = 0.22  # Airtable 5 req/sec 제한 대응

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
