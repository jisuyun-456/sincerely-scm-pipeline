{
  "permissions": {
    "allow": [
      "Bash(python3 -:*)",
      "Bash(npm run:*)",
      "Bash(git:*)",
      "Bash(bash .claude/hooks/*)"
    ],
    "deny": [
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-sql-safety.sh"
          }
        ]
      }
    ]
  }
}
